<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Almanack of Kenneth C. Moncur</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif&family=IBM+Plex+Sans&display=swap" rel="stylesheet">
  <style>
    :root {
      --turquoise: #00b7c2;
      --yellow: #ffc72c;
      --black: #222222;
      --white: #ffffff;
      --gray: #f7f7f7;
    }
    body {
      font-family: 'IBM Plex Sans', sans-serif;
      background: var(--white);
      color: var(--black);
      margin: 0;
      padding: 0;
      line-height: 1.6;
      box-sizing: border-box;
    }
    h1, h2, h3 {
      font-family: 'IBM Plex Serif', serif;
    }
    .site-header {
      padding: 1rem;
      text-align: center;
      border-bottom: 1px solid #eee;
      position: relative;
    }
    .site-header-title {
      font-family: 'IBM Plex Serif', serif;
      font-weight: 400;
      font-size: 1.05rem;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .site-header-title a {
      color: #333333;
      text-decoration: none;
    }
    .site-header-title .divider {
      color: #ccc;
      margin: 0 0.5rem;
    }
    /* Hamburger menu styles */
    .hamburger {
      position: absolute;
      left: 1.5rem;
      top: 1.2rem;
      width: 32px;
      height: 32px;
      background: none;
      border: none;
      cursor: pointer;
      z-index: 1001;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hamburger span, .hamburger span:before, .hamburger span:after {
      display: block;
      background: var(--black);
      height: 3px;
      width: 24px;
      border-radius: 2px;
      position: absolute;
      transition: all 0.3s;
      content: '';
    }
    .hamburger span {
      position: relative;
    }
    .hamburger span:before {
      content: '';
      top: -8px;
      position: absolute;
    }
    .hamburger span:after {
      content: '';
      top: 8px;
      position: absolute;
    }
    /* Side menu styles */
    .side-menu {
      position: fixed;
      top: 0;
      left: -300px;
      width: 260px;
      height: 100vh;
      background: #fff;
      box-shadow: 2px 0 16px rgba(0,0,0,0.08);
      z-index: 1002;
      padding: 2.5rem 1.5rem 1.5rem 1.5rem;
      transition: left 0.3s;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }
    .side-menu.open {
      left: 0;
    }
    .side-menu .close-btn {
      background: none;
      border: none;
      font-size: 1.7rem;
      color: var(--black);
      align-self: flex-end;
      cursor: pointer;
      margin-bottom: 2rem;
    }
    .side-menu ul {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem 0;
    }
    .side-menu ul li {
      font-family: 'IBM Plex Sans', sans-serif;
      font-size: 1.1rem;
      margin: 1.1rem 0;
      color: #444;
      font-weight: 500;
      cursor: pointer;
      transition: color 0.2s;
    }
    .side-menu ul li.active {
      color: #bbb;
      font-weight: 700;
      cursor: default;
    }
    .side-menu .side-footer {
      font-size: 0.95rem;
      color: #444444;
      text-align: center;
      margin-top: auto;
      border-top: 1px solid #eee;
      padding-top: 1.5rem;
      padding-bottom: 1rem;
      overflow-wrap: break-word;
      max-width: 90%;
      margin-left: auto;
      margin-right: auto;
    }
    .side-menu-bg {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.08);
      z-index: 1000;
    }
    .side-menu.open ~ .side-menu-bg {
      display: block;
    }
    .main-container {
      display: flex;
      flex-direction: row;
      justify-content: center;
      align-items: stretch;
      max-width: 1024px;
      margin: 0 auto;
      padding: 3rem 1rem;
      min-height: 100vh;
      box-sizing: border-box;
    }
    .content-column {
      flex: 3;
      padding-right: 3rem;
      font-size: 1.05rem;
      line-height: 1.8;
      color: #333333;
    }
    .sidebar-column {
      flex: 1;
      padding-top: 0;
    }
    .sidebar-column.sidebar-align-body {
      margin-top: 5rem;
    }
    .page-title {
      font-family: 'IBM Plex Serif', serif;
      font-size: 2.2rem;
      font-weight: 700;
      text-align: center;
      margin-top: 0;
      margin-bottom: 1rem;
      color: var(--turquoise);
    }
    .title-divider {
      width: 40px;
      height: 3px;
      background-color: var(--turquoise);
      margin: 0 auto 3rem auto;
      border: 0;
    }
    a {
      color: var(--black);
      text-decoration: none;
      border-bottom: 1px solid #ccc;
      transition: all 0.2s;
    }
    a:hover {
      color: var(--turquoise);
      border-bottom-color: var(--turquoise);
    }
    h2 {
      font-family: 'IBM Plex Serif', serif;
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.9rem;
      letter-spacing: 1px;
      margin-top: 2.5rem;
    }
    ul {
      list-style: none;
      padding-left: 0;
    }
    .content-column p {
      margin-bottom: 1.3rem;
    }
    .author-block {
      text-align: center;
    }
    .author-block img {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      margin-bottom: 1rem;
    }
    .author-block .author-name {
      font-family: 'IBM Plex Serif', serif;
      font-weight: 700;
      color: var(--turquoise);
      font-size: 0.9rem;
      text-transform: uppercase;
    }
    .author-block .author-bio {
      font-size: 0.95rem;
      color: #444444;
      line-height: 1.7;
    }
    .sidebar-block h3 {
      font-family: 'IBM Plex Serif', serif;
      font-weight: 700;
      font-size: 0.9rem;
      text-transform: uppercase;
    }
    .sidebar-block p {
      font-size: 0.9rem;
      color: #444444;
    }
    /* Homepage layout & typography */
    .home-hero,
    .home-philosophy,
    .home-almanack,
    .home-featured,
    .home-start,
    .home-subscribe {
      max-width: 760px;
      margin: 0 auto 3.5rem auto;
    }
    .home-hero {
      margin-top: 3rem;
      padding-top: 1rem;
    }
    .home-hero-eyebrow {
      font-family: 'IBM Plex Sans', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #777777;
      margin-bottom: 0.75rem;
    }
    .home-hero-title {
      font-family: 'IBM Plex Serif', serif;
      font-size: 3.25rem;
      line-height: 1.05;
      margin: 0 0 0.75rem 0;
    }
    .home-hero-subtitle {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: #777777;
      margin-bottom: 0.75rem;
    }
    .home-hero-desc {
      max-width: 40rem;
      color: #333333;
      margin-bottom: 1.5rem;
    }
    .home-hero-parts {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1.25rem;
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #777777;
      margin-bottom: 1.75rem;
    }
    .home-hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
    }
    .home-btn {
      display: inline-block;
      padding: 0.65rem 1.4rem;
      font-size: 0.85rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      border-radius: 999px;
      border: 1px solid #cccccc;
      background: transparent;
      color: #222222;
    }
    .home-btn-primary {
      background: var(--black);
      color: var(--white);
      border-color: var(--black);
    }
    .home-btn-secondary {
      background: #f7f7f7;
      color: #222222;
      border-color: #dddddd;
    }
    .home-section-header {
      margin-bottom: 1rem;
    }
    .home-section-label {
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #777777;
      margin-bottom: 0.4rem;
    }
    .home-section-header h2 {
      font-family: 'IBM Plex Serif', serif;
      font-size: 1.7rem;
      margin: 0;
    }
    .home-section-intro {
      max-width: 40rem;
      color: #333333;
      margin-bottom: 1.5rem;
    }
    .home-philosophy-text p:first-child {
      font-style: italic;
    }
    .home-philosophy-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      margin: 2rem 0 2.5rem 0;
      gap: 1rem;
    }
    .home-signature {
      font-family: 'IBM Plex Serif', serif;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-size: 0.85rem;
    }
    .home-philosophy-links a {
      margin-right: 1.25rem;
      font-size: 0.85rem;
      border-bottom: 1px solid #bbbbbb;
    }
    .home-pillars {
      display: grid;
      grid-template-columns: repeat(2, minmax(0,1fr));
      gap: 2rem;
    }
    .home-pillar-number {
      font-family: 'IBM Plex Sans', sans-serif;
      font-size: 0.8rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #777777;
      margin-right: 0.5rem;
    }
    .home-parts-grid,
    .home-featured-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0,1fr));
      gap: 2rem;
    }
    .home-part-card,
    .home-featured-card {
      border-top: 1px solid #e3e3e3;
      padding-top: 1.25rem;
      margin-top: 0.75rem;
    }
    .home-part-meta,
    .home-featured-meta {
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #777777;
      margin-bottom: 0.5rem;
    }
    .home-part-count,
    .home-featured-tag {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #555555;
      margin-top: 0.75rem;
    }
    .home-featured-footer {
      margin-top: 2rem;
    }
    .home-start-cta {
      margin: 1.5rem 0 1rem 0;
    }
    .home-quote {
      font-style: italic;
      color: #444444;
      margin-top: 1.5rem;
    }
    .home-subscribe-note {
      font-size: 0.85rem;
      color: #555555;
      margin-top: 0.75rem;
    }
    .home-footer-meta {
      margin-top: 2.5rem;
      font-size: 0.85rem;
      color: #555555;
    }
    .home-footer-title {
      font-family: 'IBM Plex Serif', serif;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }
    .home-footer-legal {
      margin-top: 0.75rem;
      color: #777777;
    }
    @media (max-width: 800px) {
      .main-container { flex-direction: column; }
      .content-column { padding-right: 0; }
      .sidebar-column { padding-top: 2rem; }
      .home-hero,
      .home-philosophy,
      .home-almanack,
      .home-featured,
      .home-start,
      .home-subscribe {
        padding: 0 0.25rem;
        margin-bottom: 2.75rem;
      }
      .home-hero-title {
        font-size: 2.4rem;
      }
      .home-pillars,
      .home-parts-grid,
      .home-featured-grid {
        grid-template-columns: 1fr;
      }
      .home-hero-ctas {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <button class="hamburger" id="hamburgerBtn" aria-label="Open menu">
    <span></span>
  </button>
  <nav class="side-menu" id="sideMenu">
    <button class="close-btn" id="closeMenuBtn" aria-label="Close menu">&times;</button>
    <ul>
      <li onclick="window.location.href='/'">Home</li>
      <li onclick="window.location.href='/pages/table_of_contents/'">Books</li>
      <li>Essays</li>
      <li>Quizzes</li>
      <li>Media Gallery</li>
      <li>About</li>
      <li>Contact</li>
    </ul>
    <div class="side-footer">
      Thank you for visiting the site. Enjoy the published content and the book. We appreciate your support, and please pay it forward.
    </div>
  </nav>
  <div class="side-menu-bg" id="sideMenuBg"></div>
  <header class="site-header">
    <div style="display: flex; justify-content: center; align-items: center; width: 100%;">
      <div class="site-header-title">
        <a href="/">
          ALMANACK OF KENNETH C. MONCUR <span class="divider">•</span> SYSTEMS • CODE • LEGACY
        </a>
      </div>
    </div>
  </header>
  {% if title == "Table of Contents" %}
  <section style="text-align: center; padding: 1.05rem 1rem 5rem;">
    <h1 style="font-family: 'IBM Plex Serif', serif; font-weight: bold; font-size: 3.5rem; margin-bottom: 0.5rem;">
      START HERE
    </h1>
    <p style="font-style: italic; font-size: 1.05rem; color: #444; max-width: 600px; margin: 0 auto;">
      A personal guide to freedom, systems, and sovereign thinking in the digital age.
    </p>
  </section>
  {% endif %}
  <div class="main-container">
    <main class="content-column">
      
      {{ content | safe }}
    </main>
    {% if show_sidebar %}
    <aside class="sidebar-column sidebar-align-body">
      <div class="author-block">
        <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=150&q=80" alt="Kenneth Moncur">
        <div class="author-name">Kenneth C. Moncur</div>
        <p class="author-bio">Author, digital freedom advocate, and Bahamian thinker.</p>
        <a href="mailto:kenneth@bahamas.com">Contact</a>
      </div>
      <div class="sidebar-block" style="margin-top: 3rem;">
        <div style="text-align: center;">
          <h3>About the Almanac</h3>
          <p>A guide to digital freedom, discipline, and legacy—rooted in Bahamian culture and global curiosity.</p>
        </div>
      </div>
    </aside>
    {% endif %}
  </div>
  <script>
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const sideMenu = document.getElementById('sideMenu');
    const closeMenuBtn = document.getElementById('closeMenuBtn');
    const sideMenuBg = document.getElementById('sideMenuBg');
    hamburgerBtn.addEventListener('click', () => {
      sideMenu.classList.add('open');
      sideMenuBg.style.display = 'block';
    });
    closeMenuBtn.addEventListener('click', () => {
      sideMenu.classList.remove('open');
      sideMenuBg.style.display = 'none';
    });
    sideMenuBg.addEventListener('click', () => {
      sideMenu.classList.remove('open');
      sideMenuBg.style.display = 'none';
    });
  </script>
</body>
</html> 